# Environment defaults for db-restore-orchestrator.
# Do not put database passwords in this file.

# true logs the selected backup and actions without dropping or restoring data.
DRY_RUN=true

# false by default so scheduled jobs do not hang. If true in an interactive
# session, the runner asks you to type the job name before restoring.
REQUIRE_CONFIRMATION=false

# Optional: force confirmation even in non-interactive sessions. Usually leave false.
REQUIRE_CONFIRMATION_FORCE=false

# Optional overrides.
# CONFIG_FILE=/opt/db-restore-orchestrator/config/restore-jobs.yml
# LOG_FILE=/opt/db-restore-orchestrator/logs/restore.log

# PostgreSQL password handling: use .pgpass or pgpass.conf instead of env vars.
# PGPASSFILE=/secure/path/.pgpass

# MySQL password handling: use ~/.my.cnf, my.ini, or --defaults-extra-file in
# client option files instead of logging or scripting passwords.
# MYSQL_HOME=/secure/mysql/options

# Oracle password handling: prefer Oracle Wallet or restricted environment/config.
